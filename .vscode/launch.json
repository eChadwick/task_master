{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Backend Models (Isolated)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
              "backend/",
              "-v",
              "-s",
              "-x",
              "--cov=.",
              "--cov-report=term-missing"
            ],
            "python": "${workspaceFolder}/backend/.venv/bin/python",
            "linux": {
              "python": "${workspaceFolder}/backend/.venv/bin/python"
            },
            "console": "integratedTerminal",
            "justMyCode": true,
          }
    ]
  }